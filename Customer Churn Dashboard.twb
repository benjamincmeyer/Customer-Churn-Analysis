      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_2382968468381697]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END)' />
